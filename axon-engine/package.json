{
  "name": "@axon/engine",
  "version": "0.1.0",
  "description": "Reference implementation of the Axon Policy Language (APL) — parse, evaluate, and audit autonomous AI agent actions.",
  "license": "MIT",
  "author": "Axon Labs <hello@axon.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/axon-labs/axon-engine"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test test/*.ts",
    "lint": "eslint src",
    "example": "tsx examples/run.ts"
  },
  "keywords": [
    "apl",
    "agent-policy-language",
    "ai-agents",
    "compliance",
    "eu-ai-act",
    "mica",
    "x402",
    "mpp",
    "ap2",
    "solana",
    "governance"
  ],
  "dependencies": {
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
