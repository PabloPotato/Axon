{
  "name": "@axon/audit",
  "version": "0.1.0",
  "description": "Auditor-signable PDF exporter for Axon — maps hash-chained action records to EU AI Act Article 12, MiCA CASP, and DORA.",
  "license": "MIT",
  "author": "Axon Labs <hello@axon.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/PabloPotato/Axon"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --import tsx --test test/*.ts",
    "example": "tsx examples/run.ts"
  },
  "keywords": [
    "axon",
    "audit",
    "pdf",
    "compliance",
    "eu-ai-act",
    "mica",
    "dora",
    "regulator-ready"
  ],
  "dependencies": {
    "@axon/engine": "file:../axon-engine",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
